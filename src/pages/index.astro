---
import Layout from "../layouts/Layout.astro";
import Hero from "@/components/home/Hero.astro";
import About from "@/components/home/About.astro";
import DentalProject from "@/components/home/DentalProject.astro";
import WorkExperience from "@/components/home/WorkExperience.astro";
import Technologies from "@/components/home/Technologies.astro";
---

<Layout>
  <Hero />
  <About />
  <div class="bg-primary w-screen px-8 py-16 text-white lg:px-24 lg:py-24">
    <div class="max-w-desktop mx-auto grid grid-cols-1 gap-24 lg:grid-cols-2">
      <WorkExperience />
      <div class="space-y-8">
        <h2 class="text-3xl font-semibold md:text-4xl">Stack Tecnológico</h2>
        <Technologies />
      </div>
    </div>
  </div>
  <DentalProject />
</Layout>
<script type="application/ld+json" is:inline>
