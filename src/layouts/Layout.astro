---
import "../styles/global.css";
import Footer from "@/components/home/Footer.astro";
import Header from "@/components/home/Header.astro";
import Analytics from "@vercel/analytics/astro";

const {
  title = "Ibrahim Sanusi | Full Stack Developer",
  description = "Full Stack Developer con experiencia en backend y sistemas en producción. Especialista en JavaScript, TypeScript, React, Node.js y SQL.",
  canonical,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="robots" content="index, follow" />
    <link
      rel="canonical"
      href={`https://ibrasanusi.com/${canonical ?? ""}`.replace(/\/$/, "")}
    />
    <meta name="generator" content={Astro.generator} />
    <title>
      {title}
    </title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Full Stack Developer, Backend Developer, JavaScript, TypeScript, Node.js, React, SQL, Desarrollador Web, Ingeniero de Software, Ibrahim Sanusi"
    />
  </head>
  <body>
    <Header />
    <slot />
    <Analytics />
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }
  body,
  html {
    margin: 0;
    width: 100vw;
  }

  body.scroll-y-none {
    overflow-y: hidden;
  }
</style>
