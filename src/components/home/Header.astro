---
import BurgerIcon from "../ui/icons/BurgerIcon.astro";
import Button from "../ui/Button.astro";
---

<header class="">
  <div class="max-w-desktop mx-auto p-3.5 flex items-center justify-between">
    <img src="logo.png" alt="logo de ibrasanusi" class="w-[100px]" />

    <nav class="hidden md:flex md:flex-row md:gap-[26px]">
      <a href="" class="font-semibold">Inicio</a>
      <a href="" class="font-semibold">Servicios</a>
      <a href="" class="font-semibold">Porfolio</a>
      <a href="" class="font-semibold">Contacto</a>
    </nav>

    <div class="hidden md:block">
      <Button>Explícame tu caso</Button>
    </div>

    <div class="flex items-stretch gap-2 md:hidden">
      <div>
        <Button>Explícame tu caso</Button>
      </div>
      <button class="px-4 py-2 bg-secondary rounded-lg">
        <BurgerIcon />
      </button>
    </div>
  </div>
</header>
