---
import { Image } from "astro:assets";
import BurgerIcon from "../ui/icons/BurgerIcon.astro";
import Button from "../ui/Button.astro";
import logo from "public/logo.png";

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios" },
  { label: "Porfolio", href: "/porfolio" },
  { label: "Contacto", href: "/contacto" },
];
---

<header>
  <div class="max-w-desktop mx-auto flex items-center justify-between p-3.5">
    <a href="/"
      ><Image
        src={logo}
        alt="logo de ibrasanusi"
        class="w-[100px]"
        widths={[480, 760, 1200]}
      /></a
    >

    <nav class="hidden md:flex md:flex-row md:gap-[26px]">
      {
        navLinks.map(({ label, href }) => (
          <a
            href={href}
            class="flex h-6 flex-col overflow-y-hidden font-semibold *:transform *:transition-transform *:duration-500 hover:*:-translate-y-6"
          >
            <span>{label}</span>
            <span class="text-brand">{label}</span>
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <Button>Explícame tu caso</Button>
    </div>

    <div class="flex items-stretch gap-2 md:hidden">
      <div>
        <Button>Explícame tu caso</Button>
      </div>
      <button class="bg-secondary rounded-lg p-2">
        <BurgerIcon class="size-10" />
      </button>
    </div>
  </div>
</header>

<div
  id="floating_cta"
  class="fixed -top-16 right-2 flex flex-row items-center gap-2 transition-transform lg:right-8"
>
  <Button>Explícame tu caso</Button>
  <button class="bg-ternary rounded-lg p-2">
    <BurgerIcon class="size-10" />
  </button>
</div>

<style>
  @keyframes drop-cta {
    to {
      transform: translateY(90px);
    }
  }

  #floating_cta {
    animation-name: drop-cta;
    animation-fill-mode: both;

    animation-timeline: scroll();
    animation-range: 100px 300px;
  }
</style>
