---
const process = [
  {
    title: "Lo mantengo simple",
    description:
      "Trabajo únicamente con clínicas dentales. Analizo cómo entran ahora las solicitudes y detecto dónde se pierde tiempo o información.",
    imageUrl: "planning.jpg",
  },
  {
    title: "Diseño la solución",
    description:
      "Tengo una reunión contigo, entiendo el problema y diseño un sistema sencillo para organizar y priorizar las solicitudes desde el primer contacto.",
    imageUrl: "girl-stressed.jpg",
  },
  {
    title: "Entrega y validación",
    description:
      "Confirmamos que todo funciona como esperabas. Te explico el sistema y, si tiene sentido, seguimos mejorándolo con nuevas automatizaciones.",
    imageUrl: "project-ended.jpg",
  },
];
---

<section class="bg-ternary w-screen px-8 py-16 lg:px-24 lg:py-24">
  <div class="max-w-desktop mx-auto flex flex-col space-y-20">
    <!-- Título sección -->
    <header class="space-y-4">
      <h2 class="text-3xl font-semibold md:text-5xl lg:text-6xl">
        Cómo trabajo con clínicas dentales
      </h2>
      <p class="text-lg text-black/70">
        Un proceso claro, sin complicaciones y orientado a reducir carga de
        trabajo en recepción.
      </p>
    </header>

    <!-- Pasos -->
    <section class="flex flex-col space-y-24 md:space-y-32">
      {
        process.map((item, index) => (
          <article
            class={`flex flex-col items-center gap-12 md:flex-row md:items-center ${
              index === 1 ? "md:flex-row-reverse" : ""
            }`}
          >
            <div class="flex flex-1 flex-col gap-4">
              <span class="text-brand text-sm font-medium tracking-wide uppercase">
                Paso {index + 1}
              </span>

              <h3 class="text-3xl font-semibold">{item.title}</h3>

              <p class="max-w-[45ch] text-xl text-black/70">
                {item.description}
              </p>

              {index === process.length - 1 && (
                <div class="pt-4">
                  <a
                    href="/contacto"
                    class="bg-brand w-full max-w-3xs place-self-center rounded-lg px-6 py-4 font-bold text-white hover:bg-blue-700 lg:max-w-[210px] lg:place-self-start"
                  >
                    Explícame tu caso
                  </a>
                </div>
              )}
            </div>

            <div class="flex-1">
              <img
                class="mx-auto w-full max-w-md rounded-xl"
                src={item.imageUrl}
                alt={`Imagen de ${item.title}`}
              />
            </div>
          </article>
        ))
      }
    </section>
  </div>
</section>
