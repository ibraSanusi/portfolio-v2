---
import Link from "../ui/Link.astro";
---

<section class="w-screen p-8 md:h-screen lg:px-24">
  <div
    class="max-w-desktop mx-auto flex h-full w-full flex-col items-center space-y-8 lg:flex-row lg:gap-6"
  >
    <article class="flex w-full flex-col gap-6">
      <div class="mx-auto space-y-4 md:mx-0">
        <span
          class="text-muted block text-center text-sm tracking-wide uppercase lg:text-start"
        >
          Full Stack Developer
        </span>

        <h1
          class="max-w-[20ch] text-center text-2xl leading-tight font-semibold md:text-5xl lg:text-start lg:text-4xl"
        >
          Construyendo sistemas web robustos y escalables
        </h1>
      </div>

      <p
        class="mx-auto w-full max-w-[40ch] text-center text-xl lg:mx-0 lg:max-w-[40ch] lg:text-start"
      >
        Especializado en backend con un enfoque en aplicaciones web en producción. 
        Experto en JavaScript, TypeScript, React, Node.js y SQL.
      </p>
      <div class="flex flex-col gap-4 md:flex-row">
        <Link href="#projects">Ver proyectos</Link>
        <Link href="/contacto" variants="secondary">Contactar</Link>
      </div>
    </article>

    <div class="order-1 w-full rounded-lg">
      <img
        class="mx-auto w-full max-w-[720px] rounded-lg lg:mx-0"
        src="working-image.jpg"
        alt="Foto de Ibrahim de perfil"
      />
    </div>
  </div>
</section>
